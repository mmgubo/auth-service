        {
          "name": "Dashboard - User Role (expect 403)",
          "event": [
            {
              "listen": "pre-request",
              "script": {
                "exec": [
                  "// Obtain a token for a USER-role account and paste it below,",
                  "// or update the username/password variables to a non-admin user",
                  "// before running this request."
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403', () => pm.response.to.have.status(403));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer REPLACE_WITH_USER_ROLE_TOKEN",
                "description": "Paste a token for a user who only has ROLE_USER (not ROLE_ADMIN)"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/dashboard",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "dashboard"]
            },
            "description": "Verifies that a USER-role token is rejected with 403 on an ADMIN endpoint."
          }
        }
      ]
    }
  ]
