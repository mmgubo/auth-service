          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('access_token present', () => {",
                  "    pm.expect(pm.response.json().access_token).to.be.a('string');",
                  "});",
                  "pm.test('refresh_token present', () => {",
                  "    pm.expect(pm.response.json().refresh_token).to.be.a('string');",
                  "});",
                  "pm.test('expires_in present', () => {",
                  "    pm.expect(pm.response.json().expires_in).to.be.a('number');",
                  "});",
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "    pm.collectionVariables.set('accessToken', json.access_token);",
                  "    console.log('✅ accessToken refreshed and saved');",
                  "}",
                  "if (json.refresh_token) {",
                  "    pm.collectionVariables.set('refreshToken', json.refresh_token);",
                  "    console.log('✅ refreshToken rotated and saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            },
            "description": "Exchanges the stored `refreshToken` for a new access + refresh token pair. Both `accessToken` and `refreshToken` collection variables are updated automatically by the test script.\n\nNo Authorization header is needed — the endpoint is intentionally unauthenticated since the access token is expired when a refresh is required."
          }
        },
