          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Revokes the refresh token at Keycloak, ending the session.\n\nRequires a valid Bearer token (inherited from collection auth).\n\nThe test script clears both `accessToken` and `refreshToken` collection variables on success so subsequent requests correctly fail until a new token is obtained."
          }
